<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhuxianwiki.mapper.CategoryMapper">

    <select id="selectRootCategories" resultType="com.zhuxianwiki.entity.Category">
        SELECT * FROM category 
        WHERE parent_id = 0 AND status = 1 
        ORDER BY sort_order ASC
    </select>

    <select id="selectChildrenByParentId" resultType="com.zhuxianwiki.entity.Category">
        SELECT * FROM category 
        WHERE parent_id = #{parentId} AND status = 1 
        ORDER BY sort_order ASC
    </select>

</mapper>
